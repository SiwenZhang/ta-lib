# Default: normalize text files to LF in the repo, check out native on Windows
* text=auto eol=lf

# Force LF for cross-platform sources
*.c        text eol=lf
*.h        text eol=lf
*.cpp      text eol=lf
*.hpp      text eol=lf
*.md       text eol=lf
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.sh       text eol=lf working-tree-encoding=UTF-8

# Windows-only files keep CRLF
*.sln      text eol=crlf
*.vcxproj  text eol=crlf
*.filters  text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Binary (never touch)
*.png  binary
*.jpg  binary
*.ico  binary
*.lib  binary
*.dll  binary
*.exe  binary
*.pdb  binary